# Copy to ".env" and fill in secrets (never commit .env).
# FastAPI / scripts read these via os.environ — load .env in your shell or IDE.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=lam123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=football_ai

# Optional single URL (overrides the pieces above if set):
# DATABASE_URL=postgresql+psycopg2://postgres:change_me@localhost:5432/football_ai

# football-data.org token for ingestion scripts (copy to .env, never commit real token here)
FOOTBALL_DATA_TOKEN=
